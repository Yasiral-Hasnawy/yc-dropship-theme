[
  {
    "name": "theme_info",
    "theme_name": "YC Web Design Dropship",
    "theme_version": "0.1.0",
    "theme_author": "Shopify",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      },
      {
        "type": "range",
        "id": "theme_corner_radius",
        "min": 0,
        "max": 32,
        "step": 1,
        "unit": "px",
        "label": "Theme corner radius",
        "default": 16
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "default": "#FFFFFF",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#333333",
        "label": "t:labels.foreground"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      }
    ]
  },
  {
    "name": "Buttons",
    "settings": [
      {
        "type": "range",
        "id": "button_corner_radius",
        "min": 0,
        "max": 48,
        "step": 1,
        "unit": "px",
        "label": "Button corner radius",
        "default": 24
      },
      {
        "type": "color",
        "id": "button_primary_background",
        "default": "#111111",
        "label": "Primary button background"
      },
      {
        "type": "color",
        "id": "button_primary_text",
        "default": "#FFFFFF",
        "label": "Primary button text"
      },
      {
        "type": "color",
        "id": "button_primary_border",
        "default": "#111111",
        "label": "Primary button border"
      },
      {
        "type": "color",
        "id": "button_primary_background_hover",
        "default": "#333333",
        "label": "Primary button hover background"
      },
      {
        "type": "color",
        "id": "button_primary_text_hover",
        "default": "#FFFFFF",
        "label": "Primary button hover text"
      },
      {
        "type": "color",
        "id": "button_primary_border_hover",
        "default": "#333333",
        "label": "Primary button hover border"
      },
      {
        "type": "color",
        "id": "button_secondary_background",
        "default": "#FFFFFF",
        "label": "Secondary button background"
      },
      {
        "type": "color",
        "id": "button_secondary_text",
        "default": "#111111",
        "label": "Secondary button text"
      },
      {
        "type": "color",
        "id": "button_secondary_border",
        "default": "#111111",
        "label": "Secondary button border"
      },
      {
        "type": "color",
        "id": "button_secondary_background_hover",
        "default": "#F2F2F2",
        "label": "Secondary button hover background"
      },
      {
        "type": "color",
        "id": "button_secondary_text_hover",
        "default": "#111111",
        "label": "Secondary button hover text"
      },
      {
        "type": "color",
        "id": "button_secondary_border_hover",
        "default": "#111111",
        "label": "Secondary button hover border"
      }
    ]
  },
  {
    "name": "Product tiles",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_quick_shop",
        "label": "Enable quick shop feature",
        "default": false
      },
      {
        "type": "text",
        "id": "quick_shop_button_text",
        "label": "Quick shop button text",
        "default": "Quick view"
      },
      {
        "type": "select",
        "id": "product_tile_image_size",
        "label": "Force image size",
        "options": [
          {
            "value": "natural",
            "label": "Natural"
          },
          {
            "value": "square",
            "label": "Square (1:1)"
          },
          {
            "value": "portrait",
            "label": "Portrait (4:5)"
          },
          {
            "value": "landscape",
            "label": "Landscape (4:3)"
          }
        ],
        "default": "square"
      },
      {
        "type": "checkbox",
        "id": "product_tile_zoom_image",
        "label": "Zoom image to fill space",
        "default": false
      },
      {
        "type": "paragraph",
        "content": "No effect when grid image size set to 'Natural'."
      },
      {
        "type": "checkbox",
        "id": "product_tile_show_second_image",
        "label": "Hover to reveal second image",
        "default": true
      },
      {
        "type": "header",
        "content": "Color swatches"
      },
      {
        "type": "checkbox",
        "id": "enable_color_swatches",
        "label": "Enable color swatches",
        "default": false
      },
      {
        "type": "radio",
        "id": "product_tile_swatch_style",
        "label": "Swatch style",
        "options": [
          {
            "value": "round",
            "label": "Round"
          },
          {
            "value": "square",
            "label": "Square"
          }
        ],
        "default": "round"
      },
      {
        "type": "textarea",
        "id": "color_swatch_mappings",
        "label": "Color swatch mappings",
        "info": "One per line, for example: Black: #111111",
        "default": "Black: #111111\nWhite: #F5F5F5\nCream: #F3E7D3\nBeige: #D8C3A5\nNavy: #1F2A44"
      }
    ]
  },
  {
    "name": "Colelction Tiles",
    "settings": [
      {
        "type": "select",
        "id": "collection_tile_style",
        "label": "Style",
        "options": [
          {
            "value": "overlay",
            "label": "Text on image overlay"
          },
          {
            "value": "overlay_bg",
            "label": "Text on image with bg"
          },
          {
            "value": "below",
            "label": "Text below image"
          }
        ],
        "default": "below"
      },
      {
        "type": "paragraph",
        "content": "Text on image overlay uses a subtle bottom fade for contrast. Text on image with bg places the title inside a small background label over the image."
      },
      {
        "type": "select",
        "id": "collection_tile_shape",
        "label": "Shape",
        "options": [
          {
            "value": "square",
            "label": "Square"
          },
          {
            "value": "landscape",
            "label": "Landscape"
          },
          {
            "value": "portrait",
            "label": "Portrait"
          }
        ],
        "default": "square"
      },
      {
        "type": "select",
        "id": "collection_tile_image_source",
        "label": "Image",
        "options": [
          {
            "value": "first_product",
            "label": "First product"
          },
          {
            "value": "collection_image",
            "label": "Collection image"
          }
        ],
        "default": "collection_image"
      },
      {
        "type": "select",
        "id": "collection_tile_text_alignment",
        "label": "Text alignment",
        "options": [
          {
            "value": "left",
            "label": "Left"
          },
          {
            "value": "center",
            "label": "Center"
          },
          {
            "value": "right",
            "label": "Right"
          }
        ],
        "default": "left"
      },
      {
        "type": "paragraph",
        "content": "Text alignment applies to all collection tile styles. For text on image with bg, it also controls whether the label sits left, center, or right on the image."
      },
      {
        "type": "header",
        "content": "Text on image with bg only"
      },
      {
        "type": "paragraph",
        "content": "The settings below only apply when Style is set to Text on image with bg."
      },
      {
        "type": "color",
        "id": "collection_tile_text_color",
        "label": "Text color",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "collection_tile_text_background",
        "label": "Text BG",
        "default": "#111111"
      },
      {
        "type": "range",
        "id": "collection_tile_tint_opacity",
        "min": 0,
        "max": 100,
        "step": 5,
        "unit": "%",
        "label": "Tint opacity",
        "default": 35
      },
      {
        "type": "color",
        "id": "collection_tile_tint_color",
        "label": "Tint color",
        "default": "#111111"
      }
    ]
  }
]
