                          <svg xmlns="http://www.w3.org/2000/svg" class="product-info__payment-method-badge" aria-labelledby="pi-bancontact" role="img" viewBox="0 0 38 24"><title id="pi-bancontact">Bancontact</title><path fill="#000" opacity=".07" d="M35 0H3C1.3 0 0 1.3 0 3v18c0 1.7 1.4 3 3 3h32c1.7 0 3-1.3 3-3V3c0-1.7-1.4-3-3-3z"></path><path fill="#fff" d="M35 1c1.1 0 2 .9 2 2v18c0 1.1-.9 2-2 2H3c-1.1 0-2-.9-2-2V3c0-1.1.9-2 2-2h32"></path><path d="M4.703 3.077h28.594c.139 0 .276.023.405.068.128.045.244.11.343.194a.9.9 0 0 1 .229.29c.053.107.08.223.08.34V20.03a.829.829 0 0 1-.31.631 1.164 1.164 0 0 1-.747.262H4.703a1.23 1.23 0 0 1-.405-.068 1.09 1.09 0 0 1-.343-.194.9.9 0 0 1-.229-.29.773.773 0 0 1-.08-.34V3.97c0-.118.027-.234.08-.342a.899.899 0 0 1 .23-.29c.098-.082.214-.148.342-.193a1.23 1.23 0 0 1 .405-.068Z" fill="#fff"></path><path d="M6.38 18.562v-3.077h1.125c.818 0 1.344.259 1.344.795 0 .304-.167.515-.401.638.338.132.536.387.536.734 0 .62-.536.91-1.37.91H6.38Zm.724-1.798h.537c.328 0 .468-.136.468-.387 0-.268-.255-.356-.599-.356h-.406v.743Zm0 1.262h.448c.438 0 .693-.093.693-.383 0-.286-.219-.404-.63-.404h-.51v.787Zm3.284.589c-.713 0-1.073-.295-1.073-.69 0-.436.422-.69 1.047-.695.156.002.31.014.464.035v-.105c0-.269-.183-.396-.531-.396a2.128 2.128 0 0 0-.688.105l-.13-.474a3.01 3.01 0 0 1 .9-.132c.767 0 1.147.343 1.147.936v1.222c-.214.093-.615.194-1.136.194Zm.438-.497v-.47a2.06 2.06 0 0 0-.37-.036c-.24 0-.427.08-.427.286 0 .185.156.281.432.281a.947.947 0 0 0 .365-.061Zm1.204.444v-2.106a3.699 3.699 0 0 1 1.177-.193c.76 0 1.198.316 1.198.9v1.399h-.719v-1.354c0-.303-.167-.444-.484-.444a1.267 1.267 0 0 0-.459.079v1.719h-.713Zm4.886-2.167-.135.479a1.834 1.834 0 0 0-.588-.11c-.422 0-.652.25-.652.664 0 .453.24.685.688.685.2-.004.397-.043.578-.114l.115.488a2.035 2.035 0 0 1-.75.128c-.865 0-1.365-.453-1.365-1.17 0-.712.495-1.182 1.323-1.182.27-.001.538.043.787.132Zm1.553 2.22c-.802 0-1.302-.47-1.302-1.178 0-.704.5-1.174 1.302-1.174.807 0 1.297.47 1.297 1.173 0 .708-.49 1.179-1.297 1.179Zm0-.502c.37 0 .563-.259.563-.677 0-.413-.193-.672-.563-.672-.364 0-.568.26-.568.672 0 .418.204.677.568.677Zm1.713.449v-2.106a3.699 3.699 0 0 1 1.177-.193c.76 0 1.198.316 1.198.9v1.399h-.719v-1.354c0-.303-.166-.444-.484-.444a1.268 1.268 0 0 0-.459.079v1.719h-.713Zm3.996.053c-.62 0-.938-.286-.938-.866v-.95h-.354v-.484h.355v-.488l.718-.03v.518h.578v.484h-.578v.94c0 .256.125.374.36.374.093 0 .185-.008.276-.026l.036.488c-.149.028-.3.041-.453.04Zm1.814 0c-.713 0-1.073-.295-1.073-.69 0-.436.422-.69 1.047-.695.155.002.31.014.464.035v-.105c0-.269-.183-.396-.532-.396a2.128 2.128 0 0 0-.687.105l-.13-.474a3.01 3.01 0 0 1 .9-.132c.766 0 1.146.343 1.146.936v1.222c-.213.093-.614.194-1.135.194Zm.438-.497v-.47a2.06 2.06 0 0 0-.37-.036c-.24 0-.427.08-.427.286 0 .185.156.281.432.281a.946.946 0 0 0 .365-.061Zm3.157-1.723-.136.479a1.834 1.834 0 0 0-.588-.11c-.422 0-.651.25-.651.664 0 .453.24.685.687.685.2-.004.397-.043.578-.114l.115.488a2.035 2.035 0 0 1-.75.128c-.865 0-1.365-.453-1.365-1.17 0-.712.495-1.182 1.323-1.182.27-.001.538.043.787.132Zm1.58 2.22c-.62 0-.938-.286-.938-.866v-.95h-.354v-.484h.354v-.488l.72-.03v.518h.577v.484h-.578v.94c0 .256.125.374.36.374.092 0 .185-.008.276-.026l.036.488c-.149.028-.3.041-.453.04Z" fill="#1E3764"></path><path d="M11.394 13.946c3.803 0 5.705-2.14 7.606-4.28H6.38v4.28h5.014Z" fill="url(#pi-bancontact-a)"></path><path d="M26.607 5.385c-3.804 0-5.705 2.14-7.607 4.28h12.62v-4.28h-5.013Z" fill="url(#pi-bancontact-b)"></path><defs><linearGradient id="pi-bancontact-a" x1="8.933" y1="12.003" x2="17.734" y2="8.13" gradientUnits="userSpaceOnUse"><stop stop-color="#005AB9"></stop><stop offset="1" stop-color="#1E3764"></stop></linearGradient><linearGradient id="pi-bancontact-b" x1="19.764" y1="10.037" x2="29.171" y2="6.235" gradientUnits="userSpaceOnUse"><stop stop-color="#FBA900"></stop><stop offset="1" stop-color="#FFD800"></stop></linearGradient></defs></svg>
                        {% else %}
                          <svg
                            class="product-info__payment-method-badge product-info__payment-method-badge--placeholder"
                            viewBox="0 0 96 56"
                            role="img"
                            aria-label="{{ payment_label }}"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <rect
                              x="1"
                              y="1"
                              width="94"
                              height="54"
                              rx="10"
                              fill="var(--payment-method-badge-background)"
                              stroke="var(--payment-method-badge-border)"
                              stroke-width="2"
                            />
                            <text
                              x="48"
                              y="31"
                              text-anchor="middle"
                              dominant-baseline="middle"
                              fill="var(--payment-method-badge-text)"
                            >
                              {{ payment_label }}
                            </text>
                          </svg>
                      {% endcase %}
                    </li>
                  {% endif %}
                {% endfor %}
              {% endcapture %}
              {% if has_payment_method %}
                <div
                  class="product-info__payment-methods"
                  style="
                    --payment-method-badge-width: {{ block.settings.icon_width }}px;
                    --payment-method-badge-height: {{ block.settings.icon_height }}px;
                    --payment-method-gap: {{ block.settings.gap }}px;
                    --payment-method-badge-background: {{ block.settings.badge_background }};
                    --payment-method-badge-border: {{ block.settings.badge_border }};
                    --payment-method-badge-text: {{ block.settings.badge_text }};
                  "
                >
                  {% if block.settings.heading != blank %}
                    <p class="product-info__support-heading">{{ block.settings.heading }}</p>
                  {% endif %}
                  <ul class="product-info__payment-method-list" role="list">
                    {{ payment_method_items }}
                  </ul>
                </div>
              {% endif %}
            {% when 'people_wearing' %}
              <div
                class="product-info__people-wearing"
                style="
                  --people-wearing-avatar-size: {{ block.settings.avatar_size }}px;
                  --people-wearing-gap: {{ block.settings.gap }}px;
                  --people-wearing-text-size: {{ block.settings.text_size }}px;
                  --people-wearing-text-color: {{ block.settings.text_color }};
                "
              >
                {% if block.settings.avatar != blank %}
                  {{
                    block.settings.avatar
                    | image_url: width: 200, height: 200, crop: 'center'
                    | image_tag: loading: 'lazy', class: 'product-info__people-wearing-avatar', alt: customer_avatar_alt
                  }}
                {% elsif block.settings.avatar_url != blank %}
                  {% # theme-check-disable RemoteAsset %}
                  <img
                    src="{{ block.settings.avatar_url }}"
                    alt="{{ customer_avatar_alt }}"
                    loading="lazy"
                    class="product-info__people-wearing-avatar"
                    width="{{ block.settings.avatar_size }}"
                    height="{{ block.settings.avatar_size }}"
                  >
                  {% # theme-check-enable RemoteAsset %}
                {% endif %}

                <p class="product-info__people-wearing-text">
                  <strong>{{ block.settings.names }}</strong> and <strong>{{ block.settings.count }}</strong>
                  {{ block.settings.suffix_text }}
                  <strong>{{ block.settings.product_name }}</strong>
                </p>
              </div>
            {% when 'sale_announcement_1' %}
              <div
                class="product-info__sale-announcement"
                style="
                  --sale-announcement-background: {{ block.settings.background }};
                  --sale-announcement-border-color: {{ block.settings.border_color }};
                  --sale-announcement-border-width: {{ block.settings.border_width }}px;
                  --sale-announcement-padding: {{ block.settings.padding }}px;
                  --sale-announcement-radius: {{ block.settings.border_radius }}px;
                  --sale-announcement-heading-color: {{ block.settings.heading_color }};
                  --sale-announcement-heading-size: {{ block.settings.heading_size }}px;
                  --sale-announcement-heading-spacing: {{ block.settings.heading_spacing }}px;
                  --sale-announcement-subheading-color: {{ block.settings.subheading_color }};
                  --sale-announcement-subheading-size: {{ block.settings.subheading_size }}px;
                  --sale-announcement-body-color: {{ block.settings.body_color }};
                  --sale-announcement-body-size: {{ block.settings.body_size }}px;
                "
              >
                <p class="product-info__sale-announcement-heading">{{ block.settings.heading }}</p>
                <p class="product-info__sale-announcement-subheading">{{ block.settings.subheading }}</p>
                <p class="product-info__sale-announcement-body">{{ block.settings.body }}</p>
              </div>
            {% when 'sale_announcement_2' %}
              <div
                class="product-info__sale-announcement-2"
                style="
                  --sale-announcement-2-background: {{ block.settings.background }};
                  --sale-announcement-2-text: {{ block.settings.text_color }};
                  --sale-announcement-2-padding: {{ block.settings.padding }}px;
                  --sale-announcement-2-radius: {{ block.settings.border_radius }}px;
                  --sale-announcement-2-text-size: {{ block.settings.text_size }}px;
                "
              >
                <p class="product-info__sale-announcement-2-text">
                  <strong>{{ block.settings.prefix }}</strong>
                  {{ block.settings.body }}
                </p>
              </div>
            {% when 'buy_buttons' %}
              {% render 'buy-buttons', form: form, current_variant: current_variant, block: block %}
            {% when 'text' %}
              {% if block.settings.heading != blank %}
                <h2 class="product-info__support-heading">{{ block.settings.heading }}</h2>
              {% endif %}
              <div class="product-info__support-copy rte">{{ block.settings.content }}</div>
            {% when 'accordion' %}
              {% assign accordion_id = 'Product-content-' | append: section.id | append: '-' | append: block.id %}
              {% assign accordion_is_open = block.settings.open_by_default %}
              <div class="product-info__accordion product-info__accordion-wrapper collapsibles-wrapper collapsibles-wrapper--border-bottom">
                <button
                  type="button"
                  class="product-info__accordion-trigger label collapsible-trigger collapsible-trigger-btn collapsible-trigger-btn--borders collapsible--auto-height{% if accordion_is_open %} is-open{% endif %}"
                  aria-controls="{{ accordion_id }}"
                  aria-expanded="{% if accordion_is_open %}true{% else %}false{% endif %}"
                  data-accordion-trigger
                >
                  {{ block.settings.heading | default: default_details_heading }}
                  <span class="product-info__accordion-icon collapsible-trigger__icon collapsible-trigger__icon--open" role="presentation">
                    <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon--wide icon-chevron-down" viewBox="0 0 28 16">
                      <path d="m1.57 1.59 12.76 12.77L27.1 1.59" stroke-width="2" stroke="currentColor" fill="none"></path>
                    </svg>
                  </span>
                </button>
                <div
                  id="{{ accordion_id }}"
                  class="product-info__accordion-panel collapsible-content collapsible-content--all{% if accordion_is_open %} is-open{% endif %}"
                  data-accordion-panel
                  {% if accordion_is_open %}
                    data-accordion-open-default="true"
                  {% endif %}
                  style="height: {% if accordion_is_open %}auto{% else %}0{% endif %};"
                >
                  <div class="product-info__accordion-content collapsible-content__inner rte">{{ block.settings.content }}</div>
                </div>
              </div>
            {% when 'image' %}
              {% if block.settings.image %}
                <figure class="product-info__editorial-image">
                  {{
                    block.settings.image
                    | image_url: width: 1400
                    | image_tag: loading: 'lazy', class: 'product-info__editorial-image-tag'
                  }}
                  {% if block.settings.caption != blank %}
                    <figcaption>{{ block.settings.caption }}</figcaption>
                  {% endif %}
                </figure>
              {% endif %}
            {% when 'sales_points' %}
              <div
                class="product-info__yc-points"
                style="
                  --yc-point-text: {{ block.settings.text_color }};
                  --yc-point-icon-size: {{ block.settings.icon_size }}px;
                "
              >
                {% if block.settings.text_1 != blank %}
                  <div class="product-info__yc-point">
                    <div class="product-info__yc-point-icon">
                      {% if block.settings.icon_1 %}
                        {{
                          block.settings.icon_1
                          | image_url: width: 72, height: 72, crop: 'center'
                          | image_tag: loading: 'lazy', class: 'product-info__yc-point-image'
                        }}
                      {% elsif block.settings.icon_1_url != blank %}
                        {% # theme-check-disable RemoteAsset %}
                        <img
                          src="{{ block.settings.icon_1_url }}"
                          alt=""
                          loading="lazy"
                          class="product-info__yc-point-image"
                          width="36"
                          height="36"
                        >
                        {% # theme-check-enable RemoteAsset %}
                      {% else %}
                        <img
                          src="{{ 'Shipping.webp' | asset_url }}"
                          alt=""
                          loading="lazy"
                          class="product-info__yc-point-image"
                          width="36"
                          height="36"
                        >
                      {% endif %}
                    </div>
                    <div class="product-info__yc-point-text">
                      <span>{{ block.settings.text_1 }}</span>
                    </div>
                  </div>
                {% endif %}

                {% if block.settings.text_2 != blank %}
                  <div class="product-info__yc-point">
                    <div class="product-info__yc-point-icon">
                      {% if block.settings.icon_2 %}
                        {{
                          block.settings.icon_2
                          | image_url: width: 72, height: 72, crop: 'center'
                          | image_tag: loading: 'lazy', class: 'product-info__yc-point-image'
                        }}
                      {% elsif block.settings.icon_2_url != blank %}
                        {% # theme-check-disable RemoteAsset %}
                        <img
                          src="{{ block.settings.icon_2_url }}"
                          alt=""
                          loading="lazy"
                          class="product-info__yc-point-image"
                          width="36"
                          height="36"
                        >
                        {% # theme-check-enable RemoteAsset %}
                      {% else %}
                        <img
                          src="{{ 'Return.webp' | asset_url }}"
                          alt=""
                          loading="lazy"
                          class="product-info__yc-point-image"
                          width="36"
                          height="36"
                        >
                      {% endif %}
                    </div>
                    <div class="product-info__yc-point-text">
                      <span>{{ block.settings.text_2 }}</span>
                    </div>
                  </div>
                {% endif %}

                {% if block.settings.text_3 != blank %}
                  <div class="product-info__yc-point">
                    <div class="product-info__yc-point-icon">
                      {% if block.settings.icon_3 %}
                        {{
                          block.settings.icon_3
                          | image_url: width: 72, height: 72, crop: 'center'
                          | image_tag: loading: 'lazy', class: 'product-info__yc-point-image'
                        }}
                      {% elsif block.settings.icon_3_url != blank %}
                        {% # theme-check-disable RemoteAsset %}
                        <img
                          src="{{ block.settings.icon_3_url }}"
                          alt=""
                          loading="lazy"
                          class="product-info__yc-point-image"
                          width="36"
                          height="36"
                        >
                        {% # theme-check-enable RemoteAsset %}
                      {% else %}
                        <img
                          src="{{ 'Heart.webp' | asset_url }}"
                          alt=""
                          loading="lazy"
                          class="product-info__yc-point-image"
                          width="36"
                          height="36"
                        >
                      {% endif %}
                    </div>
                    <div class="product-info__yc-point-text">
                      <span>{{ block.settings.text_3 }}</span>
                    </div>
                  </div>
                {% endif %}
              </div>
          {% endcase %}
        </div>
      {% endcapture %}

      {% if block_group != '' and current_group != block_group %}
        {% capture rendered_groups %}
          {{ rendered_groups }}
          <div class="product-info__group product-info__group--{{ block_group }}">
            {{ group_markup }}
          </div>
        {% endcapture %}
        {% assign group_markup = '' %}
      {% endif %}

      {% assign block_group = current_group %}
      {% capture group_markup %}
        {{ group_markup }}
        {{ block_markup }}
      {% endcapture %}
    {% endfor %}

    {% if group_markup != blank %}
      {% capture rendered_groups %}
        {{ rendered_groups }}
        <div class="product-info__group product-info__group--{{ block_group }}">
          {{ group_markup }}
        </div>
      {% endcapture %}
    {% endif %}

    {{ rendered_groups }}
  {% endform %}

  {% if placement == 'info' and section.settings.enable_sticky_bar %}
    <div class="product-sticky-bar" data-sticky-bar hidden>
      <div class="product-sticky-bar__content">
        <div>
          <p class="product-sticky-bar__title">{{ product.title }}</p>
          <p class="product-sticky-bar__price" data-sticky-price>{{ current_variant.price | money }}</p>
        </div>
        <button type="button" class="button button--primary" data-sticky-submit>
          {{ sticky_label }}
        </button>
      </div>
    </div>
  {% endif %}
</div>
