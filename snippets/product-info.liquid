{% liquid
  assign lower_zone_types = 'text,image,sales_points' | split: ','
%}

{% if placement == blank %}
  {% assign placement = 'info' %}
{% endif %}

{% assign sticky_label = 'product.add_to_cart' | t %}
{% assign default_description_heading = 'product.description' | t %}
{% assign default_details_heading = 'product.details' | t %}
{% assign customer_avatar_alt = 'product.customer_avatar_alt' | t %}
{% for sticky_block in section.blocks %}
  {% if sticky_block.type == 'buy_buttons' and sticky_block.settings.sticky_label != blank %}
    {% assign sticky_label = sticky_block.settings.sticky_label %}
    {% break %}
  {% endif %}
{% endfor %}

<div class="product-info" data-product-info data-placement="{{ placement }}">
  {% form 'product', product, class: 'product-info__form', data-product-form: '' %}
    {% assign block_group = '' %}
    {% assign group_markup = '' %}
    {% assign rendered_groups = '' %}

    {% for block in section.blocks %}
      {% liquid
        assign block_placement = 'info'
        if lower_zone_types contains block.type
          assign block_placement = block.settings.placement | default: 'info'
        endif

        if block_placement != placement
          continue
        endif

        assign current_group = 'supporting'
        if block.type == 'title' or block.type == 'price' or block.type == 'rating'
          assign current_group = 'basic'
        elsif block.type == 'variant_picker' or block.type == 'quantity_selector' or block.type == 'buy_buttons'
          assign current_group = 'purchase'
        endif
      %}

      {% capture block_markup %}
        <div class="product-info__block product-info__block--{{ block.type }}" {{ block.shopify_attributes }}>
          {% case block.type %}
            {% when 'title' %}
              <h1 class="product-info__title">{{ product.title }}</h1>
            {% when 'price' %}
              {% liquid
                assign savings_amount = current_variant.compare_at_price | minus: current_variant.price
                assign savings_percent = 0
                assign savings_amount_formatted = savings_amount | money
                assign savings_percent_formatted = savings_percent | append: '%'
                if current_variant.compare_at_price > current_variant.price and current_variant.compare_at_price > 0
                  assign savings_percent = savings_amount | times: 100 | divided_by: current_variant.compare_at_price
                  assign savings_percent_formatted = savings_percent | append: '%'
                endif
              %}
              <div
                class="product-info__price-wrap {% if block.settings.compare_price_position == 'before' %}product-info__price-wrap--compare-first{% endif %}"
                style="
                  --product-price-color: {{ block.settings.price_color }};
                  --product-compare-price-color: {{ block.settings.compare_price_color }};
                  --product-price-size: {{ block.settings.price_size }}px;
                  --product-compare-price-size: {{ block.settings.compare_price_size }}px;
                  --product-savings-badge-background: {{ block.settings.savings_badge_background }};
                  --product-savings-badge-text: {{ block.settings.savings_badge_text }};
                "
                data-savings-format="{{ block.settings.savings_badge_format }}"
                data-savings-template-percent="{{ 'product.price.savings_badge_percent' | t: value: '[[value]]' }}"
                data-savings-template-amount="{{ 'product.price.savings_badge_amount' | t: value: '[[value]]' }}"
              >
                {% if block.settings.compare_price_position == 'before' %}
                  {% if current_variant.compare_at_price > current_variant.price %}
                    <p class="product-info__compare" data-product-compare-price>{{ current_variant.compare_at_price | money }}</p>
                  {% else %}
                    <p class="product-info__compare" data-product-compare-price hidden></p>
                  {% endif %}
                  <p class="product-info__price" data-product-price>{{ current_variant.price | money }}</p>
                {% else %}
                  <p class="product-info__price" data-product-price>{{ current_variant.price | money }}</p>
                  {% if current_variant.compare_at_price > current_variant.price %}
                    <p class="product-info__compare" data-product-compare-price>{{ current_variant.compare_at_price | money }}</p>
                  {% else %}
                    <p class="product-info__compare" data-product-compare-price hidden></p>
                  {% endif %}
                {% endif %}

                {% if block.settings.show_savings_badge %}
                  <p class="product-info__savings-badge" data-product-savings-badge {% unless current_variant.compare_at_price > current_variant.price %}hidden{% endunless %}>
                    {% if current_variant.compare_at_price > current_variant.price %}
                      {% if block.settings.savings_badge_format == 'amount' %}
                        {{ 'product.price.savings_badge_amount' | t: value: savings_amount_formatted }}
                      {% else %}
                        {{ 'product.price.savings_badge_percent' | t: value: savings_percent_formatted }}
                      {% endif %}
                    {% endif %}
                  </p>
                {% endif %}
              </div>
            {% when 'rating' %}
              <div class="product-info__rating" aria-label="{{ block.settings.rating }} out of 5 stars">
                <span>{{ block.settings.rating }}/5</span>
                <span class="product-info__rating-count">{{ block.settings.rating_count }} reviews</span>
              </div>
            {% when 'separator' %}
              <hr class="product-info__separator">
            {% when 'description' %}
              {% if block.settings.display_style == 'accordion' %}
                {% assign accordion_id = 'Product-content-' | append: section.id | append: '-' | append: block.id %}
                {% assign accordion_is_open = block.settings.accordion_open_by_default %}
                <div class="product-info__accordion product-info__accordion-wrapper collapsibles-wrapper collapsibles-wrapper--border-bottom">
                  <button
                    type="button"
                    class="product-info__accordion-trigger label collapsible-trigger collapsible-trigger-btn collapsible-trigger-btn--borders collapsible--auto-height{% if accordion_is_open %} is-open{% endif %}"
                    aria-controls="{{ accordion_id }}"
                    aria-expanded="{% if accordion_is_open %}true{% else %}false{% endif %}"
                    data-accordion-trigger
                  >
                    {{ block.settings.accordion_heading | default: default_description_heading }}
                    <span class="product-info__accordion-icon collapsible-trigger__icon collapsible-trigger__icon--open" role="presentation">
                      <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon--wide icon-chevron-down" viewBox="0 0 28 16">
                        <path d="m1.57 1.59 12.76 12.77L27.1 1.59" stroke-width="2" stroke="currentColor" fill="none"></path>
                      </svg>
                    </span>
                  </button>
                  <div
                    id="{{ accordion_id }}"
                    class="product-info__accordion-panel collapsible-content collapsible-content--all{% if accordion_is_open %} is-open{% endif %}"
                    data-accordion-panel
                    {% if accordion_is_open %}
                      data-accordion-open-default="true"
                    {% endif %}
                    style="height: {% if accordion_is_open %}auto{% else %}0{% endif %};"
                  >
                    <div class="product-info__accordion-content collapsible-content__inner product-info__description rte">
                      {{ product.description }}
                    </div>
                  </div>
                </div>
              {% else %}
                <div class="product-info__description rte">{{ product.description }}</div>
              {% endif %}
            {% when 'variant_picker' %}
              {% render 'variant-picker', product: product, current_variant: current_variant, block: block %}
            {% when 'quantity_selector' %}
              <label class="product-info__quantity">
                <span>{{ 'product.quantity' | t }}</span>
                <div class="product-info__quantity-box" data-quantity-box>
                  <button type="button" class="product-info__quantity-button" data-quantity-decrease aria-label="{{ 'cart.decrease_quantity' | t }}">
                    -
                  </button>
                  <input type="number" min="1" name="quantity" value="1" data-quantity-input>
                  <button type="button" class="product-info__quantity-button" data-quantity-increase aria-label="{{ 'cart.increase_quantity' | t }}">
                    +
                  </button>
                </div>
              </label>
            {% when 'low_stock_notice' %}
              <div
                class="product-info__low-stock"
                style="
                  --low-stock-text-size: {{ block.settings.text_size }}px;
                  --low-stock-text-color: {{ block.settings.text_color }};
                  --low-stock-dot-color: {{ block.settings.dot_color }};
                  --low-stock-dot-size: {{ block.settings.dot_size }}px;
                  --low-stock-pulse-size: {{ block.settings.pulse_size }}px;
                "
                data-low-stock-notice
                data-low-stock-text-template="{{ block.settings.text | escape }}"
                data-low-stock-delivery-days="{{ block.settings.delivery_days }}"
              >
                <div class="product-info__low-stock-icon">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="product-info__low-stock-dot product-info__low-stock-dot--animated"
                    aria-hidden="true"
                  >
                    <circle cx="12" cy="12" r="10"></circle>
                  </svg>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="product-info__low-stock-dot"
                    aria-hidden="true"
                  >
                    <circle cx="12" cy="12" r="10"></circle>
                  </svg>
                </div>
                <div class="product-info__low-stock-copy">
                  <p class="product-info__low-stock-text" data-low-stock-text>{{ block.settings.text }}</p>
                </div>
              </div>
            {% when 'review_summary' %}
              {% liquid
                assign review_link = block.settings.link
                if review_link == blank
                  assign review_link = '#'
                endif
              %}
              <div
                class="product-info__review-summary"
                style="
                  --review-summary-margin: {{ block.settings.margin }};
                  --review-summary-stars-color: {{ block.settings.stars_color }};
                  --review-summary-stars-size: {{ block.settings.stars_size }}px;
                  --review-summary-stars-spacing: {{ block.settings.stars_spacing }}px;
                  --review-summary-text-size: {{ block.settings.text_size }}px;
                  --review-summary-text-color: {{ block.settings.text_color }};
                "
              >
                <a href="{{ review_link }}" class="product-info__review-summary-link">
                  <div class="product-info__review-summary-stars">{{ block.settings.stars_text }}</div>
                  <p class="product-info__review-summary-text">{{ block.settings.text }}</p>
                </a>
              </div>
            {% when 'payment_methods' %}
              {% liquid
                assign payment_methods = 'AMEX|show_amex,Mastercard|show_mastercard,Visa|show_visa,Maestro|show_maestro,PayPal|show_paypal,Klarna|show_klarna,Shop Pay|show_shop_pay,Apple Pay|show_apple_pay,Google Pay|show_google_pay,Blik|show_blik,iDEAL|show_ideal,MobilePay|show_mobilepay,Union Pay|show_union_pay,Bancontact|show_bancontact' | split: ','
                assign has_payment_method = false
              %}
              {% capture payment_method_items %}
                {% for payment_method in payment_methods %}
                  {% assign payment_parts = payment_method | split: '|' %}
                  {% assign payment_label = payment_parts[0] %}
                  {% assign payment_key = payment_parts[1] %}
                  {% if block.settings[payment_key] %}
                    {% assign has_payment_method = true %}
                    <li class="product-info__payment-method-item">
                      {% case payment_label %}
                        {% when 'AMEX' %}
                          <svg xmlns="http://www.w3.org/2000/svg" class="product-info__payment-method-badge" role="img" aria-labelledby="pi-american_express" viewBox="0 0 38 24"><title id="pi-american_express">American Express</title><path fill="#000" d="M35 0H3C1.3 0 0 1.3 0 3v18c0 1.7 1.4 3 3 3h32c1.7 0 3-1.3 3-3V3c0-1.7-1.4-3-3-3Z" opacity=".07"></path><path fill="#006FCF" d="M35 1c1.1 0 2 .9 2 2v18c0 1.1-.9 2-2 2H3c-1.1 0-2-.9-2-2V3c0-1.1.9-2 2-2h32Z"></path><path fill="#FFF" d="M22.012 19.936v-8.421L37 11.528v2.326l-1.732 1.852L37 17.573v2.375h-2.766l-1.47-1.622-1.46 1.628-9.292-.02Z"></path><path fill="#006FCF" d="M23.013 19.012v-6.57h5.572v1.513h-3.768v1.028h3.678v1.488h-3.678v1.01h3.768v1.531h-5.572Z"></path><path fill="#006FCF" d="m28.557 19.012 3.083-3.289-3.083-3.282h2.386l1.884 2.083 1.89-2.082H37v.051l-3.017 3.23L37 18.92v.093h-2.307l-1.917-2.103-1.898 2.104h-2.321Z"></path><path fill="#FFF" d="M22.71 4.04h3.614l1.269 2.881V4.04h4.46l.77 2.159.771-2.159H37v8.421H19l3.71-8.421Z"></path><path fill="#006FCF" d="m23.395 4.955-2.916 6.566h2l.55-1.315h2.98l.55 1.315h2.05l-2.904-6.566h-2.31Zm.25 3.777.875-2.09.873 2.09h-1.748Z"></path><path fill="#006FCF" d="M28.581 11.52V4.953l2.811.01L32.84 9l1.456-4.046H37v6.565l-1.74.016v-4.51l-1.644 4.494h-1.59L30.35 7.01v4.51h-1.768Z"></path></svg>
                        {% when 'Apple Pay' %}
                          <svg version="1.1" xmlns="http://www.w3.org/2000/svg" class="product-info__payment-method-badge" role="img" viewBox="0 0 165.521 105.965" xml:space="preserve" aria-labelledby="pi-apple_pay"><title id="pi-apple_pay">Apple Pay</title><path fill="#000" d="M150.698 0H14.823c-.566 0-1.133 0-1.698.003-.477.004-.953.009-1.43.022-1.039.028-2.087.09-3.113.274a10.51 10.51 0 0 0-2.958.975 9.932 9.932 0 0 0-4.35 4.35 10.463 10.463 0 0 0-.975 2.96C.113 9.611.052 10.658.024 11.696a70.22 70.22 0 0 0-.022 1.43C0 13.69 0 14.256 0 14.823v76.318c0 .567 0 1.132.002 1.699.003.476.009.953.022 1.43.028 1.036.09 2.084.275 3.11a10.46 10.46 0 0 0 .974 2.96 9.897 9.897 0 0 0 1.83 2.52 9.874 9.874 0 0 0 2.52 1.83c.947.483 1.917.79 2.96.977 1.025.183 2.073.245 3.112.273.477.011.953.017 1.43.02.565.004 1.132.004 1.698.004h135.875c.565 0 1.132 0 1.697-.004.476-.002.952-.009 1.431-.02 1.037-.028 2.085-.09 3.113-.273a10.478 10.478 0 0 0 2.958-.977 9.955 9.955 0 0 0 4.35-4.35c.483-.947.789-1.917.974-2.96.186-1.026.246-2.074.274-3.11.013-.477.02-.954.022-1.43.004-.567.004-1.132.004-1.699V14.824c0-.567 0-1.133-.004-1.699a63.067 63.067 0 0 0-.022-1.429c-.028-1.038-.088-2.085-.274-3.112a10.4 10.4 0 0 0-.974-2.96 9.94 9.94 0 0 0-4.35-4.35A10.52 10.52 0 0 0 156.939.3c-1.028-.185-2.076-.246-3.113-.274a71.417 71.417 0 0 0-1.431-.022C151.83 0 151.263 0 150.698 0z"></path><path fill="#FFF" d="M150.698 3.532l1.672.003c.452.003.905.008 1.36.02.793.022 1.719.065 2.583.22.75.135 1.38.34 1.984.648a6.392 6.392 0 0 1 2.804 2.807c.306.6.51 1.226.645 1.983.154.854.197 1.783.218 2.58.013.45.019.9.02 1.36.005.557.005 1.113.005 1.671v76.318c0 .558 0 1.114-.004 1.682-.002.45-.008.9-.02 1.35-.022.796-.065 1.725-.221 2.589a6.855 6.855 0 0 1-.645 1.975 6.397 6.397 0 0 1-2.808 2.807c-.6.306-1.228.511-1.971.645-.881.157-1.847.2-2.574.22-.457.01-.912.017-1.379.019-.555.004-1.113.004-1.669.004H14.801c-.55 0-1.1 0-1.66-.004a74.993 74.993 0 0 1-1.35-.018c-.744-.02-1.71-.064-2.584-.22a6.938 6.938 0 0 1-1.986-.65 6.337 6.337 0 0 1-1.622-1.18 6.355 6.355 0 0 1-1.178-1.623 6.935 6.935 0 0 1-.646-1.985c-.156-.863-.2-1.788-.22-2.578a66.088 66.088 0 0 1-.02-1.355l-.003-1.327V14.474l.002-1.325a66.7 66.7 0 0 1 .02-1.357c.022-.792.065-1.717.222-2.587a6.924 6.924 0 0 1 .646-1.981c.304-.598.7-1.144 1.18-1.623a6.386 6.386 0 0 1 1.624-1.18 6.96 6.96 0 0 1 1.98-.646c.865-.155 1.792-.198 2.586-.22.452-.012.905-.017 1.354-.02l1.677-.003h135.875"></path><g><g><path fill="#000" d="M43.508 35.77c1.404-1.755 2.356-4.112 2.105-6.52-2.054.102-4.56 1.355-6.012 3.112-1.303 1.504-2.456 3.959-2.156 6.266 2.306.2 4.61-1.152 6.063-2.858"></path><path fill="#000" d="M45.587 39.079c-3.35-.2-6.196 1.9-7.795 1.9-1.6 0-4.049-1.8-6.698-1.751-3.447.05-6.645 2-8.395 5.1-3.598 6.2-.95 15.4 2.55 20.45 1.699 2.5 3.747 5.25 6.445 5.151 2.55-.1 3.549-1.65 6.647-1.65 3.097 0 3.997 1.65 6.696 1.6 2.798-.05 4.548-2.5 6.247-5 1.95-2.85 2.747-5.6 2.797-5.75-.05-.05-5.396-2.101-5.446-8.251-.05-5.15 4.198-7.6 4.398-7.751-2.399-3.548-6.147-3.948-7.447-4.048"></path></g><g><path fill="#000" d="M78.973 32.11c7.278 0 12.347 5.017 12.347 12.321 0 7.33-5.173 12.373-12.529 12.373h-8.058V69.62h-5.822V32.11h14.062zm-8.24 19.807h6.68c5.07 0 7.954-2.729 7.954-7.46 0-4.73-2.885-7.434-7.928-7.434h-6.706v14.894z"></path><path fill="#000" d="M92.764 61.847c0-4.809 3.665-7.564 10.423-7.98l7.252-.442v-2.08c0-3.04-2.001-4.704-5.562-4.704-2.938 0-5.07 1.507-5.51 3.82h-5.252c.157-4.86 4.731-8.395 10.918-8.395 6.654 0 10.995 3.483 10.995 8.89v18.663h-5.38v-4.497h-.13c-1.534 2.937-4.914 4.782-8.579 4.782-5.406 0-9.175-3.222-9.175-8.057zm17.675-2.417v-2.106l-6.472.416c-3.64.234-5.536 1.585-5.536 3.95 0 2.288 1.975 3.77 5.068 3.77 3.95 0 6.94-2.522 6.94-6.03z"></path><path fill="#000" d="M120.975 79.652v-4.496c.364.051 1.247.103 1.715.103 2.573 0 4.029-1.09 4.913-3.899l.52-1.663-9.852-27.293h6.082l6.863 22.146h.13l6.862-22.146h5.927l-10.216 28.67c-2.34 6.577-5.017 8.735-10.683 8.735-.442 0-1.872-.052-2.261-.157z"></path></g></g></svg>
                        {% when 'Google Pay' %}
