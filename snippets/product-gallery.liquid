{% liquid
  assign gallery_layout = section.settings.gallery_layout
  assign mobile_mode = section.settings.mobile_gallery_mode
%}

<div
  class="product-gallery product-gallery--{{ gallery_layout }} product-gallery--mobile-{{ mobile_mode }}"
  data-product-gallery
>
  <div class="product-gallery__viewport" data-gallery-viewport>
    {% for media in product.media %}
      {% assign is_active = false %}
      {% if current_variant.featured_media and current_variant.featured_media.id == media.id %}
        {% assign is_active = true %}
      {% elsif current_variant.featured_media == blank and forloop.first %}
        {% assign is_active = true %}
      {% endif %}

      <article
        class="product-gallery__item {% if is_active %}is-active{% endif %}"
        data-media-id="{{ media.id }}"
        data-media-type="{{ media.media_type }}"
        {% if media == current_variant.featured_media %}
          data-featured-variant-media="true"
        {% endif %}
      >
        <button
          type="button"
          class="product-gallery__zoom"
          data-gallery-zoom
          aria-label="Open {{ product.title }} media"
        >
          Zoom
        </button>

        {% case media.media_type %}
          {% when 'image' %}
            {{
              media
              | image_url: width: 1800
              | image_tag:
                loading: 'lazy',
                class: 'product-gallery__image',
                widths: '600, 900, 1200, 1500, 1800'
            }}
          {% when 'video' %}
            {{ media | video_tag: controls: true, class: 'product-gallery__video' }}
          {% when 'external_video' %}
            {{ media | external_video_tag: class: 'product-gallery__video' }}
          {% when 'model' %}
            {{ media | model_viewer_tag: reveal: 'interaction', toggleable: true, class: 'product-gallery__model' }}
          {% else %}
            <div class="product-gallery__fallback">Media unavailable</div>
        {% endcase %}
      </article>
    {% endfor %}
  </div>

  {% if product.media.size > 1 %}
    <div class="product-gallery__controls">
      <button type="button" class="product-gallery__arrow" data-gallery-prev aria-label="Previous media">
        <span>&larr;</span>
      </button>

      <div class="product-gallery__thumbs" data-gallery-thumbs>
        {% for media in product.media %}
          <button
            type="button"
            class="product-gallery__thumb {% if current_variant.featured_media and current_variant.featured_media.id == media.id %}is-active{% elsif current_variant.featured_media == blank and forloop.first %}is-active{% endif %}"
            data-gallery-thumb
            data-target-media-id="{{ media.id }}"
            aria-label="Show media {{ forloop.index }}"
          >
            {% if media.preview_image %}
              {{
                media.preview_image
                | image_url: width: 240, height: 240, crop: 'center'
                | image_tag: loading: 'lazy', class: 'product-gallery__thumb-image'
              }}
            {% endif %}
          </button>
        {% endfor %}
      </div>

      <div class="product-gallery__dots" data-gallery-dots>
        {% for media in product.media %}
          <button
            type="button"
            class="product-gallery__dot {% if current_variant.featured_media and current_variant.featured_media.id == media.id %}is-active{% elsif current_variant.featured_media == blank and forloop.first %}is-active{% endif %}"
            data-gallery-thumb
            data-target-media-id="{{ media.id }}"
            aria-label="Go to media {{ forloop.index }}"
          ></button>
        {% endfor %}
      </div>

      <button type="button" class="product-gallery__arrow" data-gallery-next aria-label="Next media">
        <span>&rarr;</span>
      </button>
    </div>
  {% endif %}

  <dialog class="product-gallery__modal" data-gallery-modal>
    <button type="button" class="product-gallery__modal-close" data-gallery-close aria-label="Close zoomed media">Close</button>
    <div class="product-gallery__modal-body" data-gallery-modal-body></div>
  </dialog>
</div>
