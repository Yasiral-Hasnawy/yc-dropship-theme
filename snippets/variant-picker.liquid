{% if product.has_only_default_variant == false %}
  <div class="product-info__variants" data-variant-picker>
    {% for option in product.options_with_values %}
      {% liquid
        assign option_name_downcase = option.name | downcase
        assign is_color = false
        assign is_size = false
        assign picker_mode = 'normal'
        if option_name_downcase contains 'color' or option_name_downcase contains 'colour'
          assign is_color = true
        endif
        if option_name_downcase contains 'size'
          assign is_size = true
        endif
        if is_color
          assign picker_mode = block.settings.color_display | default: 'color_swatch'
        endif
      %}

      <fieldset class="product-info__option-group" data-option-position="{{ option.position }}">
        <legend class="product-info__option-header">
          <span>{{ option.name }}</span>
          <span class="product-info__option-value" data-selected-option="{{ option.position }}">
            {{ option.selected_value }}
          </span>
          {% if block.settings.show_size_chart and is_size %}
            <button type="button" class="product-info__size-guide">{{ block.settings.size_chart_label }}</button>
          {% endif %}
        </legend>

        <div class="product-info__option-values product-info__option-values--{{ picker_mode }}">
          {% for value in option.values %}
            {% liquid
              assign button_classes = 'product-info__option-button'
              assign button_classes = button_classes | append: ' '
              assign button_classes = button_classes | append: 'product-info__option-button--' | append: picker_mode
              assign button_style = ''
              assign image_markup = ''

              if value == option.selected_value
                assign button_classes = button_classes | append: ' is-active'
              endif

              if picker_mode == 'color_swatch'
                assign button_style = 'background:' | append: value | append: ';'
              elsif picker_mode == 'variant_image'
                for variant in product.variants
                  assign option_index = option.position | minus: 1
                  if variant.options[option_index] == value and variant.featured_image
                    capture image_markup
                      echo variant.featured_image | image_url: width: 160, height: 160, crop: 'center' | image_tag: loading: 'lazy', class: 'product-info__option-image'
                    endcapture
                    break
                  endif
                endfor
              endif
            %}
            <button
              type="button"
              class="{{ button_classes }}"
              data-option-button
              data-option-name="{{ option.name }}"
              data-option-value="{{ value | escape }}"
              {% if button_style != blank %}
                style="{{ button_style }}"
              {% endif %}
            >
              {% if picker_mode == 'variant_image' %}
                {% if image_markup != blank %}
                  <span class="product-info__option-image-wrap">{{ image_markup }}</span>
                {% else %}
                  <span class="product-info__option-image-wrap product-info__option-image-wrap--fallback">{{ value | slice: 0 }}</span>
                {% endif %}
              {% endif %}
              <span class="product-info__option-label">{{ value }}</span>
            </button>
          {% endfor %}
        </div>
      </fieldset>
    {% endfor %}
  </div>
{% endif %}
