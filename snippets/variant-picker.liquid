{% if product.has_only_default_variant == false %}
  <div class="product-info__variants" data-variant-picker>
    {% liquid
      assign color_trigger_words = block.settings.color_trigger_words | default: 'color, colour, couleur' | downcase | split: ','
      assign size_chart_trigger_words = block.settings.size_chart_trigger_words | default: 'size, sizes' | downcase | split: ','
    %}
    {% for option in product.options_with_values %}
      {% liquid
        assign option_name_downcase = option.name | downcase
        assign is_color = false
        assign is_size = false
        assign picker_mode = 'normal'

        for trigger_word in color_trigger_words
          assign normalized_trigger_word = trigger_word | strip
          if normalized_trigger_word != blank and option_name_downcase == normalized_trigger_word
            assign is_color = true
            break
          endif
        endfor

        for trigger_word in size_chart_trigger_words
          assign normalized_trigger_word = trigger_word | strip
          if normalized_trigger_word != blank and option_name_downcase == normalized_trigger_word
            assign is_size = true
            break
          endif
        endfor
        if is_color
          assign picker_mode = block.settings.color_display | default: 'color_swatch'
        endif
      %}

      <fieldset class="product-info__option-group" data-option-position="{{ option.position }}">
        <legend class="product-info__option-header">
          <span>{{ option.name }}</span>
          <span class="product-info__option-value" data-selected-option="{{ option.position }}">
            {{ option.selected_value }}
          </span>
          {% if block.settings.show_size_chart and is_size %}
            <button type="button" class="product-info__size-guide">{{ block.settings.size_chart_label }}</button>
          {% endif %}
        </legend>

        <div class="product-info__option-values product-info__option-values--{{ picker_mode }} {% if picker_mode == 'color_swatch' and block.settings.show_color_labels == false %}product-info__option-values--labels-hidden{% endif %}">
          {% for value in option.values %}
            {% liquid
              assign normalized_value = value | strip | downcase
              if picker_mode == 'color_swatch'
                assign button_classes = 'product-info__color-swatch'
              else
                assign button_classes = 'product-info__option-button'
                assign button_classes = button_classes | append: ' '
                assign button_classes = button_classes | append: 'product-info__option-button--' | append: picker_mode
              endif
              assign button_style = ''
              assign image_markup = ''
              assign swatch_label_style = ''
              assign swatch_image = blank
              assign uses_color_label_setting = false

              if value == option.selected_value
                assign button_classes = button_classes | append: ' is-active'
              endif

              if is_color and picker_mode == 'color_swatch'
                assign uses_color_label_setting = true
              endif

              if is_color and picker_mode == 'variant_image'
                assign uses_color_label_setting = true
              endif

              if picker_mode == 'color_swatch'
                assign button_style = 'background:' | append: value | append: ';'

                assign swatch_mapping_lines = settings.color_swatch_mappings | newline_to_br | split: '<br />'
                for mapping_line in swatch_mapping_lines
                  assign mapping_parts = mapping_line | split: ':'
                  assign mapping_key = mapping_parts.first | strip | downcase
                  if mapping_key == normalized_value
                    assign mapping_value = mapping_line | remove_first: mapping_parts.first | remove_first: ':' | strip
                    if mapping_value != blank
                      assign button_style = 'background:' | append: mapping_value | append: ';'
                      assign swatch_label_style = 'background: rgba(255, 255, 255, 0.78);'
                    endif
                    break
                  endif
                endfor
              elsif picker_mode == 'variant_image'
                for variant in product.variants
                  assign option_index = option.position | minus: 1
                  if variant.options[option_index] == value
                    if variant.featured_media and variant.featured_media.preview_image
                      assign swatch_image = variant.featured_media.preview_image
                    elsif variant.image
                      assign swatch_image = variant.image
                    elsif variant.featured_image
                      assign swatch_image = variant.featured_image
                    endif

                    if swatch_image != blank
                      capture image_markup
                        echo swatch_image | image_url: width: 160, height: 160, crop: 'center' | image_tag: loading: 'lazy', class: 'product-info__option-image', widths: '80, 120, 160'
                      endcapture
                    endif

                    if image_markup != blank
                      break
                    endif
                  endif
                endfor
              endif
            %}
            <button
              type="button"
              class="{{ button_classes }}"
              data-option-button
              data-option-position="{{ option.position }}"
              data-option-name="{{ option.name }}"
              data-option-value="{{ value | escape }}"
              aria-pressed="{% if value == option.selected_value %}true{% else %}false{% endif %}"
              {% if button_style != blank %}
                style="{{ button_style }}"
              {% endif %}
            >
              {% if picker_mode == 'variant_image' %}
                {% if image_markup != blank %}
                  <span class="product-info__option-image-wrap">{{ image_markup }}</span>
                {% else %}
                  <span class="product-info__option-image-wrap product-info__option-image-wrap--fallback">{{ value | slice: 0 }}</span>
                {% endif %}
              {% endif %}
              {% if uses_color_label_setting %}
                {% if block.settings.show_color_labels %}
                  <span class="{% if picker_mode == 'color_swatch' %}product-info__color-swatch-label{% else %}product-info__option-label{% endif %}" {% if swatch_label_style != blank %}style="{{ swatch_label_style }}"{% endif %}>{{ value }}</span>
                {% endif %}
              {% else %}
                <span class="product-info__option-label">{{ value }}</span>
              {% endif %}
            </button>
          {% endfor %}
        </div>
      </fieldset>
    {% endfor %}
  </div>

  {% if block.settings.show_size_chart %}
    <dialog class="product-info__size-chart-modal" data-size-chart-modal>
      <div class="product-info__size-chart-shell">
        <button
          type="button"
          class="product-info__size-chart-close"
          data-size-chart-close
          aria-label="{{ 'product.size_guide.close' | t }}"
        >
          {{ 'general.close' | t }}
        </button>

        {% if block.settings.size_chart_heading != blank %}
          <h2 class="product-info__size-chart-heading">{{ block.settings.size_chart_heading }}</h2>
        {% endif %}

        {% if block.settings.size_chart_intro != blank %}
          <div class="product-info__size-chart-copy rte">{{ block.settings.size_chart_intro }}</div>
        {% endif %}

        {% if block.settings.size_chart_table != blank %}
          <div class="product-info__size-chart-table rte">
            {{ block.settings.size_chart_table }}
          </div>
        {% endif %}

        {% if block.settings.size_chart_image != blank %}
          <div class="product-info__size-chart-image-wrap">
            {{
              block.settings.size_chart_image
              | image_url: width: 1800
              | image_tag:
                loading: 'lazy',
                class: 'product-info__size-chart-image',
                alt: block.settings.size_chart_image_alt
            }}
          </div>
        {% endif %}

        {% if block.settings.size_chart_footer != blank %}
          <div class="product-info__size-chart-copy rte">{{ block.settings.size_chart_footer }}</div>
        {% endif %}
      </div>
    </dialog>
  {% endif %}
{% endif %}
