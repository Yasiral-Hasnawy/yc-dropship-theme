<div class="product-info__buy-buttons" data-buy-buttons>
  <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id-input>
  <button
    type="submit"
    name="add"
    class="button button--primary product-info__add"
    {% unless current_variant.available %}
      disabled
    {% endunless %}
    data-add-to-cart
  >
    <span data-add-to-cart-label>
      {% if current_variant.available %}
        Add to cart
      {% else %}
        Sold out
      {% endif %}
    </span>
  </button>

  {% if block.settings.show_dynamic_checkout %}
    {{ form | payment_button }}
  {% endif %}
</div>
