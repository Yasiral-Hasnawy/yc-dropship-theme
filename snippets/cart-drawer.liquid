{% liquid
  assign cart_compare_total = 0
  assign upgrade_tier_count = 0
  assign tier_1_threshold_cents = settings.cart_drawer_upgrade_tier_1_threshold | times: 100
  assign tier_2_threshold_cents = settings.cart_drawer_upgrade_tier_2_threshold | times: 100
  assign tier_3_threshold_cents = settings.cart_drawer_upgrade_tier_3_threshold | times: 100
  capture cart_drawer_secure_icon
    echo '<svg aria-hidden="true" focusable="false" role="presentation" class="cart-drawer__secure-icon" viewBox="0 0 24 24"><path d="M16 12h1.4a.6.6 0 0 1 .6.6v6.8a.6.6 0 0 1-.6.6H6.6a.6.6 0 0 1-.6-.6v-6.8a.6.6 0 0 1 .6-.6H8m8 0V8c0-1.333-.8-4-4-4S8 6.667 8 8v4m8 0H8" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg>'
  endcapture
  for item in cart.items
    if item.variant.compare_at_price > item.final_price
      assign item_compare_total = item.variant.compare_at_price | times: item.quantity
      assign cart_compare_total = cart_compare_total | plus: item_compare_total
    else
      assign cart_compare_total = cart_compare_total | plus: item.final_line_price
    endif
  endfor

  if settings.cart_drawer_upgrade_tier_1_reward != blank and settings.cart_drawer_upgrade_tier_1_threshold > 0
    assign upgrade_tier_count = upgrade_tier_count | plus: 1
  endif
  if settings.cart_drawer_upgrade_tier_2_reward != blank and settings.cart_drawer_upgrade_tier_2_threshold > 0
    assign upgrade_tier_count = upgrade_tier_count | plus: 1
  endif
  if settings.cart_drawer_upgrade_tier_3_reward != blank and settings.cart_drawer_upgrade_tier_3_threshold > 0
    assign upgrade_tier_count = upgrade_tier_count | plus: 1
  endif
%}

<aside
  class="cart-drawer"
  data-cart-drawer
  data-cart-currency="{{ cart.currency.iso_code }}"
  data-cart-drawer-show-compare-at="{{ settings.cart_drawer_show_compare_at }}"
  data-cart-drawer-upgrade-enabled="{{ settings.cart_drawer_upgrade_enabled }}"
  data-cart-drawer-countdown-enabled="{{ settings.cart_drawer_countdown_enabled }}"
  data-cart-drawer-countdown-minutes="{{ settings.cart_drawer_countdown_minutes }}"
  data-cart-drawer-close-label="{{ 'cart.drawer.close' | t }}"
  data-cart-drawer-empty-title="{{ 'cart.empty_title' | t }}"
  data-cart-drawer-empty-copy="{{ 'cart.empty_message' | t }}"
  data-cart-drawer-decrease-label="{{ 'cart.decrease_quantity' | t }}"
  data-cart-drawer-increase-label="{{ 'cart.increase_quantity' | t }}"
  data-cart-drawer-remove-label="{{ 'cart.remove' | t }}"
  data-cart-drawer-subtotal-label="{{ 'cart.subtotal' | t }}"
  data-cart-drawer-secure-checkout-label="{{ 'cart.secure_checkout' | t }}"
  data-cart-drawer-upgrade-complete-label="{{ 'cart.drawer.upgrade_complete' | t }}"
  data-cart-drawer-upgrade-remaining-template="{{ 'cart.drawer.upgrade_remaining_html' | t: amount: '[[amount]]', reward: '[[reward]]' }}"
  data-cart-drawer-live-template="{{ 'cart.drawer.live_region' | t: count: '[[count]]', subtotal: '[[subtotal]]' }}"
  data-cart-drawer-adding-label="{{ 'product.adding_to_cart' | t }}"
  aria-hidden="true"
  style="
    --cart-drawer-image-fit: {{ settings.cart_drawer_image_fit }};
    --cart-drawer-heading-color: {{ settings.cart_drawer_heading_color }};
    --cart-drawer-eyebrow-color: {{ settings.cart_drawer_eyebrow_color }};
    --cart-drawer-item-title-color: {{ settings.cart_drawer_item_title_color }};
    --cart-drawer-variant-color: {{ settings.cart_drawer_variant_color }};
    --cart-drawer-price-color: {{ settings.cart_drawer_price_color }};
    --cart-drawer-compare-price-color: {{ settings.cart_drawer_compare_price_color }};
    --cart-drawer-subtotal-label-color: {{ settings.cart_drawer_subtotal_label_color }};
    --cart-drawer-subtotal-price-color: {{ settings.cart_drawer_subtotal_price_color }};
    --cart-drawer-compare-subtotal-color: {{ settings.cart_drawer_compare_subtotal_color }};
    --cart-drawer-remove-color: {{ settings.cart_drawer_remove_color }};
    --cart-drawer-upgrade-background: {{ settings.cart_drawer_upgrade_background }};
    --cart-drawer-upgrade-text-color: {{ settings.cart_drawer_upgrade_text_color }};
    --cart-drawer-upgrade-muted-color: {{ settings.cart_drawer_upgrade_muted_color }};
    --cart-drawer-upgrade-progress-background: {{ settings.cart_drawer_upgrade_progress_background }};
    --cart-drawer-upgrade-progress-fill: {{ settings.cart_drawer_upgrade_progress_fill }};
  "
>
  <script type="application/json" data-cart-drawer-upgrade-config>
    {
      "enabled": {{ settings.cart_drawer_upgrade_enabled | json }},
      "heading": {{ settings.cart_drawer_upgrade_heading | json }},
      "intro": {{ settings.cart_drawer_upgrade_intro | json }},
      "completeText": {{ settings.cart_drawer_upgrade_complete_text | json }},
      "countdownEnabled": {{ settings.cart_drawer_countdown_enabled | json }},
      "countdownLabel": {{ settings.cart_drawer_countdown_label | json }},
      "countdownMinutes": {{ settings.cart_drawer_countdown_minutes | json }},
      "tiers": [
        {% if settings.cart_drawer_upgrade_tier_1_reward != blank and settings.cart_drawer_upgrade_tier_1_threshold > 0 %}
          {
            "threshold": {{ settings.cart_drawer_upgrade_tier_1_threshold | times: 100 | json }},
            "reward": {{ settings.cart_drawer_upgrade_tier_1_reward | json }}
          }{% if settings.cart_drawer_upgrade_tier_2_reward != blank and settings.cart_drawer_upgrade_tier_2_threshold > 0 or settings.cart_drawer_upgrade_tier_3_reward != blank and settings.cart_drawer_upgrade_tier_3_threshold > 0 %},{% endif %}
        {% endif %}
        {% if settings.cart_drawer_upgrade_tier_2_reward != blank and settings.cart_drawer_upgrade_tier_2_threshold > 0 %}
          {
            "threshold": {{ settings.cart_drawer_upgrade_tier_2_threshold | times: 100 | json }},
            "reward": {{ settings.cart_drawer_upgrade_tier_2_reward | json }}
          }{% if settings.cart_drawer_upgrade_tier_3_reward != blank and settings.cart_drawer_upgrade_tier_3_threshold > 0 %},{% endif %}
        {% endif %}
        {% if settings.cart_drawer_upgrade_tier_3_reward != blank and settings.cart_drawer_upgrade_tier_3_threshold > 0 %}
          {
            "threshold": {{ settings.cart_drawer_upgrade_tier_3_threshold | times: 100 | json }},
            "reward": {{ settings.cart_drawer_upgrade_tier_3_reward | json }}
          }
        {% endif %}
      ]
    }
  </script>
  <button type="button" class="cart-drawer__overlay" data-cart-drawer-close aria-label="{{ 'cart.drawer.close' | t }}"></button>

  <div class="cart-drawer__panel" role="dialog" aria-modal="true" aria-labelledby="CartDrawerTitle">
    <p class="visually-hidden" data-cart-drawer-live-region aria-live="polite"></p>
    <div class="cart-drawer__header">
      <div class="cart-drawer__header-main">
        <div>
          <p class="cart-drawer__eyebrow">{{ 'cart.drawer.eyebrow' | t }}</p>
          <h2 id="CartDrawerTitle" class="cart-drawer__title">
            {{ 'cart.title' | t }}
            <span data-cart-drawer-count>{{ cart.item_count }}</span>
          </h2>
        </div>
        <button type="button" class="cart-drawer__close" data-cart-drawer-close aria-label="{{ 'cart.drawer.close' | t }}">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>

      {% if settings.cart_drawer_upgrade_enabled and upgrade_tier_count > 0 %}
        <div class="cart-drawer__header-extension">
          <div class="cart-drawer__upgrade" data-cart-drawer-upgrade {% if cart.item_count == 0 %}hidden{% endif %}>
            <div class="cart-drawer__upgrade-top">
              {% assign next_reward = blank %}
              {% assign next_threshold = blank %}
              {% assign highest_threshold = 0 %}
              {% if settings.cart_drawer_upgrade_tier_1_reward != blank and settings.cart_drawer_upgrade_tier_1_threshold > highest_threshold %}
                {% assign highest_threshold = settings.cart_drawer_upgrade_tier_1_threshold %}
              {% endif %}
              {% if settings.cart_drawer_upgrade_tier_2_reward != blank and settings.cart_drawer_upgrade_tier_2_threshold > highest_threshold %}
                {% assign highest_threshold = settings.cart_drawer_upgrade_tier_2_threshold %}
              {% endif %}
              {% if settings.cart_drawer_upgrade_tier_3_reward != blank and settings.cart_drawer_upgrade_tier_3_threshold > highest_threshold %}
                {% assign highest_threshold = settings.cart_drawer_upgrade_tier_3_threshold %}
              {% endif %}

              {% if settings.cart_drawer_upgrade_tier_1_reward != blank and settings.cart_drawer_upgrade_tier_1_threshold > 0 and cart.total_price < tier_1_threshold_cents %}
                {% assign next_reward = settings.cart_drawer_upgrade_tier_1_reward %}
                {% assign next_threshold = tier_1_threshold_cents %}
              {% elsif settings.cart_drawer_upgrade_tier_2_reward != blank and settings.cart_drawer_upgrade_tier_2_threshold > 0 and cart.total_price < tier_2_threshold_cents %}
                {% assign next_reward = settings.cart_drawer_upgrade_tier_2_reward %}
                {% assign next_threshold = tier_2_threshold_cents %}
              {% elsif settings.cart_drawer_upgrade_tier_3_reward != blank and settings.cart_drawer_upgrade_tier_3_threshold > 0 and cart.total_price < tier_3_threshold_cents %}
                {% assign next_reward = settings.cart_drawer_upgrade_tier_3_reward %}
                {% assign next_threshold = tier_3_threshold_cents %}
              {% endif %}

              <p class="cart-drawer__upgrade-copy" data-cart-drawer-upgrade-copy>
                {% if next_reward != blank and next_threshold != blank %}
                  {% assign amount_left = next_threshold | minus: cart.total_price %}
                  {% assign amount_left_money = amount_left | money %}
                  {{ 'cart.drawer.upgrade_remaining_html' | t: amount: amount_left_money, reward: next_reward }}
                {% else %}
                  {{ settings.cart_drawer_upgrade_complete_text }}
                {% endif %}
              </p>

              {% if settings.cart_drawer_countdown_enabled %}
                <div class="cart-drawer__countdown" data-cart-drawer-countdown {% if cart.item_count == 0 %}hidden{% endif %}>
                  <span class="cart-drawer__countdown-copy">{{ settings.cart_drawer_countdown_label }}</span>
                  <strong class="cart-drawer__countdown-time" data-cart-drawer-countdown-time>{{ settings.cart_drawer_countdown_minutes | prepend: '0' | slice: -2, 2 }}:00</strong>
                </div>
              {% endif %}
            </div>

            {% assign progress_max = highest_threshold | times: 100 %}
            {% assign progress_value = cart.total_price %}
            {% if progress_max <= 0 %}
              {% assign progress_max = 100 %}
            {% endif %}
            {% if progress_value > progress_max %}
              {% assign progress_value = progress_max %}
            {% endif %}
            <div class="cart-drawer__upgrade-progress">
              <div
                class="cart-drawer__upgrade-progress-bar"
                data-cart-drawer-upgrade-progress
                style="width: {{ progress_value | times: 100.0 | divided_by: progress_max }}%;"
              ></div>
              <div class="cart-drawer__upgrade-markers" data-cart-drawer-upgrade-tiers>
                {% if settings.cart_drawer_upgrade_tier_1_reward != blank and settings.cart_drawer_upgrade_tier_1_threshold > 0 %}
                  <span
                    class="cart-drawer__upgrade-marker{% if cart.total_price >= tier_1_threshold_cents %} is-complete{% endif %}"
                    style="left: {{ tier_1_threshold_cents | times: 100.0 | divided_by: progress_max }}%;"
                    title="{{ settings.cart_drawer_upgrade_tier_1_reward }} - {{ tier_1_threshold_cents | money }}"
                  >
                    <span class="cart-drawer__upgrade-marker-icon" aria-hidden="true"><svg viewBox="0 0 10 10" focusable="false" role="presentation"><path d="M2 5.2 4.1 7.3 8 3.4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
                  </span>
                {% endif %}
                {% if settings.cart_drawer_upgrade_tier_2_reward != blank and settings.cart_drawer_upgrade_tier_2_threshold > 0 %}
                  <span
                    class="cart-drawer__upgrade-marker{% if cart.total_price >= tier_2_threshold_cents %} is-complete{% endif %}"
                    style="left: {{ tier_2_threshold_cents | times: 100.0 | divided_by: progress_max }}%;"
                    title="{{ settings.cart_drawer_upgrade_tier_2_reward }} - {{ tier_2_threshold_cents | money }}"
                  >
                    <span class="cart-drawer__upgrade-marker-icon" aria-hidden="true"><svg viewBox="0 0 10 10" focusable="false" role="presentation"><path d="M2 5.2 4.1 7.3 8 3.4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
                  </span>
                {% endif %}
                {% if settings.cart_drawer_upgrade_tier_3_reward != blank and settings.cart_drawer_upgrade_tier_3_threshold > 0 %}
                  <span
                    class="cart-drawer__upgrade-marker{% if cart.total_price >= tier_3_threshold_cents %} is-complete{% endif %}"
                    style="left: {{ tier_3_threshold_cents | times: 100.0 | divided_by: progress_max }}%;"
                    title="{{ settings.cart_drawer_upgrade_tier_3_reward }} - {{ tier_3_threshold_cents | money }}"
                  >
                    <span class="cart-drawer__upgrade-marker-icon" aria-hidden="true"><svg viewBox="0 0 10 10" focusable="false" role="presentation"><path d="M2 5.2 4.1 7.3 8 3.4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
                  </span>
                {% endif %}
              </div>
            </div>

            <div class="cart-drawer__upgrade-legend" data-cart-drawer-upgrade-legend></div>
          </div>
        </div>
      {% endif %}
    </div>

    <div class="cart-drawer__body" data-cart-drawer-body>
      {% if cart.item_count == 0 %}
        <div class="cart-drawer__empty" data-cart-drawer-empty>
          <p class="cart-drawer__empty-title">{{ 'cart.empty_title' | t }}</p>
          <p class="cart-drawer__empty-copy">{{ 'cart.empty_message' | t }}</p>
        </div>
      {% else %}
        <ul class="cart-drawer__items" data-cart-drawer-items role="list">
          {% for item in cart.items %}
            <li class="cart-drawer__item" data-cart-item-key="{{ item.key }}">
              <a href="{{ item.url }}" class="cart-drawer__item-media">
                {% if item.image %}
                  {{
                    item.image
                    | image_url: width: 320, height: 400, crop: 'center'
                    | image_tag: loading: 'lazy', class: 'cart-drawer__item-image'
                  }}
                {% endif %}
              </a>

              <div class="cart-drawer__item-content">
                <div class="cart-drawer__item-top">
                  <div>
                    <a href="{{ item.url }}" class="cart-drawer__item-title">{{ item.product.title }}</a>
                    {% if item.variant_title and item.variant_title != 'Default Title' %}
                      <p class="cart-drawer__item-variant">{{ item.variant_title }}</p>
                    {% endif %}
                  </div>
                  <div class="cart-drawer__item-prices">
                    <p class="cart-drawer__item-price">{{ item.final_line_price | money }}</p>
                    {% if settings.cart_drawer_show_compare_at and item.variant.compare_at_price > item.final_price %}
                      <p class="cart-drawer__item-compare-price">{{ item.variant.compare_at_price | times: item.quantity | money }}</p>
                    {% endif %}
                  </div>
                </div>

                <div class="cart-drawer__item-bottom">
                  <div class="cart-drawer__quantity">
                    <button type="button" class="cart-drawer__quantity-button" data-cart-quantity-change data-cart-quantity-delta="-1" aria-label="{{ 'cart.decrease_quantity' | t }}">-</button>
                    <span class="cart-drawer__quantity-value">{{ item.quantity }}</span>
                    <button type="button" class="cart-drawer__quantity-button" data-cart-quantity-change data-cart-quantity-delta="1" aria-label="{{ 'cart.increase_quantity' | t }}">+</button>
                  </div>
                  <button type="button" class="cart-drawer__remove" data-cart-remove>{{ 'cart.remove' | t }}</button>
                </div>
              </div>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>

    <div class="cart-drawer__footer" data-cart-drawer-footer {% if cart.item_count == 0 %}hidden{% endif %}>
      <div class="cart-drawer__summary">
        <div class="cart-drawer__summary-row">
          <span class="cart-drawer__subtotal-label">{{ 'cart.subtotal' | t }}</span>
          <div class="cart-drawer__subtotal-values">
            {% if settings.cart_drawer_show_compare_at and cart_compare_total > cart.total_price %}
              <p class="cart-drawer__subtotal-compare" data-cart-drawer-compare-subtotal>{{ cart_compare_total | money }}</p>
            {% else %}
              <p class="cart-drawer__subtotal-compare" data-cart-drawer-compare-subtotal hidden></p>
            {% endif %}
            <strong data-cart-drawer-subtotal>{{ cart.total_price | money }}</strong>
          </div>
        </div>
      </div>

      <div class="cart-drawer__actions">
        <a href="/checkout" class="button button--primary cart-drawer__checkout-button">
          {% if settings.cart_drawer_show_secure_icon and settings.cart_drawer_secure_icon_position == 'before' %}
            {{ cart_drawer_secure_icon }}
          {% endif %}
          <span>{{ 'cart.secure_checkout' | t }}</span>
          {% if settings.cart_drawer_show_secure_icon and settings.cart_drawer_secure_icon_position == 'after' %}
            {{ cart_drawer_secure_icon }}
          {% endif %}
        </a>
      </div>
    </div>
  </div>
</aside>
