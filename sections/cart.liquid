{% comment %}
  Cart page section with an editorial two-column layout inspired by modern Shopify themes.
{% endcomment %}

<section class="cart-page section-{{ section.id }}">
  <div class="cart-page__inner">
    {% if cart.item_count == 0 %}
      <div class="cart-page__empty">
        <p class="cart-page__eyebrow">{{ 'cart.drawer.eyebrow' | t }}</p>
        <h1 class="cart-page__title">{{ 'cart.title' | t }}</h1>
        <p class="cart-page__empty-copy">{{ 'cart.empty_message' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="button button--primary">{{ 'cart.continue_shopping' | t }}</a>
      </div>
    {% else %}
      <div class="cart-page__header">
        <div>
          <p class="cart-page__eyebrow">{{ 'cart.drawer.eyebrow' | t }}</p>
          <h1 class="cart-page__title">{{ 'cart.title' | t }}</h1>
        </div>
        <p class="cart-page__count">{{ 'cart.item_count' | t: count: cart.item_count }}</p>
      </div>

      <form action="{{ routes.cart_url }}" method="post" class="cart-page__form">
        <div class="cart-page__grid">
          <div class="cart-page__items">
            {% for item in cart.items %}
              <article class="cart-page__item">
                <a href="{{ item.url }}" class="cart-page__item-media">
                  {% if item.image %}
                    {{
                      item.image
                      | image_url: width: 640, height: 800, crop: 'center'
                      | image_tag: loading: 'lazy', class: 'cart-page__item-image'
                    }}
                  {% endif %}
                </a>

                <div class="cart-page__item-content">
                  <div class="cart-page__item-top">
                    <div>
                      <a href="{{ item.url }}" class="cart-page__item-title">{{ item.product.title }}</a>
                      {% if item.variant_title and item.variant_title != 'Default Title' %}
                        <p class="cart-page__item-meta">{{ item.variant_title }}</p>
                      {% endif %}
                      {% if item.selling_plan_allocation %}
                        <p class="cart-page__item-meta">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                      {% endif %}
                    </div>

                    <div class="cart-page__item-pricing">
                      <p class="cart-page__item-price">{{ item.final_line_price | money }}</p>
                      {% if item.original_line_price > item.final_line_price %}
                        <p class="cart-page__item-compare">{{ item.original_line_price | money }}</p>
                      {% endif %}
                    </div>
                  </div>

                  <div class="cart-page__item-bottom">
                    <label class="cart-page__quantity">
                      <span class="visually-hidden">{{ 'cart.quantity_for_product' | t: product: item.product.title }}</span>
                      <input
                        type="number"
                        min="0"
                        name="updates[]"
                        value="{{ item.quantity }}"
                        class="cart-page__quantity-input"
                      >
                    </label>

                    <a href="{{ item.url_to_remove }}" class="cart-page__remove">{{ 'cart.remove' | t }}</a>
                  </div>
                </div>
              </article>
            {% endfor %}
          </div>

          <aside class="cart-page__summary">
            <div class="cart-page__summary-card">
              <h2 class="cart-page__summary-title">{{ 'cart.order_summary' | t }}</h2>

              <div class="cart-page__summary-row">
                <span>{{ 'cart.subtotal' | t }}</span>
                <strong>{{ cart.total_price | money }}</strong>
              </div>

              {% if cart.cart_level_discount_applications != blank %}
                {% for discount in cart.cart_level_discount_applications %}
                  <div class="cart-page__summary-row cart-page__summary-row--discount">
                    <span>{{ discount.title }}</span>
                    <strong>-{{ discount.total_allocated_amount | money }}</strong>
                  </div>
                {% endfor %}
              {% endif %}

              <label class="cart-page__note">
                <span>{{ 'cart.order_note' | t }}</span>
                <textarea name="note" rows="4" placeholder="{{ 'cart.order_note_placeholder' | t }}">{{ cart.note }}</textarea>
              </label>

              <div class="cart-page__actions">
                <button class="button button--secondary" type="submit" name="update">
                  {{ 'cart.update' | t }}
                </button>
                <button class="button button--primary" type="submit" name="checkout">
                  {{ 'cart.checkout' | t }}
                </button>
              </div>
            </div>
          </aside>
        </div>
      </form>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .cart-page {
    padding-block: 40px 72px;
  }

  .cart-page__inner {
    width: min(100% - 32px, var(--page-width));
    margin-inline: auto;
    display: grid;
    gap: 28px;
  }

  .cart-page__header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
  }

  .cart-page__eyebrow {
    margin: 0 0 0.45rem;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(16, 24, 32, 0.64);
  }

  .cart-page__title {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
  }

  .cart-page__count,
  .cart-page__item-meta,
  .cart-page__summary-note,
  .cart-page__empty-copy {
    color: rgba(16, 24, 32, 0.68);
  }

  .cart-page__form,
  .cart-page__items,
  .cart-page__summary-card,
  .cart-page__actions,
  .cart-page__empty {
    display: grid;
    gap: 18px;
  }

  .cart-page__grid {
    display: grid;
    gap: 24px;
  }

  .cart-page__item {
    display: grid;
    grid-template-columns: 120px minmax(0, 1fr);
    gap: 18px;
    padding-bottom: 18px;
    border-bottom: 1px solid rgba(16, 24, 32, 0.08);
  }

  .cart-page__item-media {
    display: block;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--style-border-radius-theme);
    background: rgba(16, 24, 32, 0.04);
  }

  .cart-page__item-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-page__item-content,
  .cart-page__item-top {
    display: grid;
    gap: 12px;
  }

  .cart-page__item-top {
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: start;
  }

  .cart-page__item-title {
    color: inherit;
    text-decoration: none;
    font-weight: 600;
    line-height: 1.3;
  }

  .cart-page__item-pricing {
    text-align: right;
  }

  .cart-page__item-price,
  .cart-page__item-compare {
    margin: 0;
  }

  .cart-page__item-price {
    font-weight: 600;
  }

  .cart-page__item-compare {
    text-decoration: line-through;
    color: rgba(16, 24, 32, 0.5);
  }

  .cart-page__item-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .cart-page__quantity-input,
  .cart-page__note textarea {
    border: 1px solid rgba(16, 24, 32, 0.12);
    border-radius: var(--style-border-radius-buttons);
    background: transparent;
    font: inherit;
  }

  .cart-page__quantity-input {
    width: 84px;
    min-height: 46px;
    padding: 0.65rem 0.8rem;
  }

  .cart-page__remove {
    color: rgba(16, 24, 32, 0.68);
    text-decoration: underline;
  }

  .cart-page__summary {
    min-width: 0;
  }

  .cart-page__summary-card {
    padding: 22px;
    border: 1px solid rgba(16, 24, 32, 0.08);
    border-radius: var(--style-border-radius-theme);
    background: rgba(255, 255, 255, 0.9);
  }

  .cart-page__summary-title {
    margin: 0;
    font-size: 1.15rem;
  }

  .cart-page__summary-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .cart-page__summary-row--discount {
    color: #0f7a4b;
  }

  .cart-page__note {
    display: grid;
    gap: 10px;
  }

  .cart-page__note span {
    font-weight: 600;
  }

  .cart-page__note textarea {
    width: 100%;
    padding: 0.9rem 1rem;
    resize: vertical;
  }

  .cart-page__actions {
    grid-template-columns: 1fr;
  }

  .cart-page__actions .button {
    width: 100%;
  }

  .cart-page__empty {
    justify-items: start;
    max-width: 560px;
    min-height: 50vh;
    align-content: center;
  }

  @media (min-width: 990px) {
    .cart-page__grid {
      grid-template-columns: minmax(0, 1.5fr) minmax(320px, 0.8fr);
      align-items: start;
    }

    .cart-page__summary-card {
      position: sticky;
      top: 24px;
    }
  }

  @media (max-width: 749px) {
    .cart-page__header {
      align-items: start;
      flex-direction: column;
    }

    .cart-page__item {
      grid-template-columns: 88px minmax(0, 1fr);
    }

    .cart-page__item-top {
      grid-template-columns: 1fr;
    }

    .cart-page__item-pricing {
      text-align: left;
    }

    .cart-page__item-bottom {
      align-items: flex-start;
      flex-direction: column;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
