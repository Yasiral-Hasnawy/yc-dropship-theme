{% if section.blocks.size > 0 %}
  {% assign text_align = section.settings.text_align | default: 'left' %}
  <section
    class="rich-text-section rich-text-section--align-{{ text_align }} full-width"
    id="RichText-{{ section.id }}"
    style="
      --rich-text-gap: {{ section.settings.gap }}px;
      --rich-text-align: {{ text_align }};
    "
  >
    <div class="rich-text-section__inner">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'heading' %}
            {% if block.settings.text != blank %}
              <h2 class="rich-text-section__heading" {{ block.shopify_attributes }}>{{ block.settings.text }}</h2>
            {% endif %}
          {% when 'text' %}
            {% if block.settings.text != blank %}
              <div class="rich-text-section__text rte" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>
            {% endif %}
          {% when 'button' %}
            {% if block.settings.label != blank and block.settings.link != blank %}
              <a
                class="rich-text-section__button button button--{{ block.settings.style | default: 'primary' }}"
                href="{{ block.settings.link }}"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.label }}
              </a>
            {% endif %}
          {% when 'html' %}
            {% if block.settings.html != blank %}
              <div class="rich-text-section__html" {{ block.shopify_attributes }}>
                {{ block.settings.html }}
              </div>
            {% endif %}
        {% endcase %}
      {% endfor %}
    </div>
  </section>
{% endif %}

{% stylesheet %}
  .rich-text-section {
    padding: 56px 0;
  }

  .rich-text-section__inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--rich-text-gap);
    width: min(var(--page-width), calc(100% - var(--page-margin) * 2));
    margin: 0 auto;
    text-align: var(--rich-text-align);
  }

  .rich-text-section__heading {
    margin: 0;
  }

  .rich-text-section__text {
    max-width: 65ch;
  }

  .rich-text-section__button {
    max-width: 100%;
  }

  .rich-text-section__html {
    width: 100%;
  }

  .rich-text-section--align-center .rich-text-section__inner {
    align-items: center;
  }

  .rich-text-section--align-right .rich-text-section__inner {
    align-items: flex-end;
  }

  .rich-text-section__text > *:first-child {
    margin-top: 0;
  }

  .rich-text-section__text > *:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 749px) {
    .rich-text-section {
      padding: 40px 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Rich text",
  "tag": "section",
  "class": "section-rich-text",
  "settings": [
    {
      "type": "range",
      "id": "gap",
      "label": "Gap",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text align",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Heading",
          "default": "Rich text"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add a short paragraph here to share details about your brand, products, or promotion.</p>"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "style",
          "label": "Style",
          "options": [
            {
              "value": "primary",
              "label": "Primary"
            },
            {
              "value": "secondary",
              "label": "Secondary"
            }
          ],
          "default": "primary"
        }
      ]
    },
    {
      "type": "html",
      "name": "HTML",
      "settings": [
        {
          "type": "textarea",
          "id": "html",
          "label": "HTML",
          "default": "<div>Custom HTML</div>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Rich text",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "text"
        },
        {
          "type": "button"
        }
      ]
    }
  ]
}
{% endschema %}
