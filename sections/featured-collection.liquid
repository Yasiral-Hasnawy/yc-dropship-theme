{% liquid
  assign featured_collection = section.settings.collection
  assign products_per_row = section.settings.products_per_row | default: 4
  assign rows = section.settings.rows | default: 1
  assign products_to_show = products_per_row | times: rows
  assign view_all_position = section.settings.view_all_position | default: 'header'
  assign view_all_style = section.settings.view_all_style | default: 'link'
  assign show_view_all = section.settings.show_view_all
  assign enable_swipe_on_mobile = section.settings.enable_swipe_on_mobile
  assign desktop_image_size = 100 | divided_by: products_per_row
  assign image_sizes = '(max-width: 749px) 80vw, (max-width: 989px) 50vw, '
  assign image_sizes = image_sizes | append: desktop_image_size | append: 'vw'
%}

<section
  class="featured-collection-section full-width{% if section.settings.show_section_divider %} featured-collection-section--divider{% endif %}"
  id="FeaturedCollection-{{ section.id }}"
  style="--featured-collection-columns: {{ products_per_row }};"
>
  <div class="featured-collection-section__inner">
    {% if section.settings.heading != blank or show_view_all and featured_collection != blank and view_all_position == 'header' %}
      <div class="featured-collection-section__header">
        {% if section.settings.heading != blank %}
          <h2 class="featured-collection-section__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if show_view_all and featured_collection != blank and view_all_position == 'header' %}
          <a
            class="featured-collection-section__view-all-link{% if view_all_style == 'primary' %} button button--primary{% elsif view_all_style == 'secondary' %} button button--secondary{% endif %}"
            href="{{ featured_collection.url }}"
          >
            {{ 'View all' }}
          </a>
        {% endif %}
      </div>
    {% endif %}

    <div class="featured-collection-section__grid-wrapper{% if enable_swipe_on_mobile %} featured-collection-section__grid-wrapper--mobile-swipe{% endif %}">
      <div class="featured-collection-section__grid" role="list">
        {% if featured_collection != blank and featured_collection.products_count > 0 %}
          {% for product in featured_collection.products limit: products_to_show %}
            <div class="featured-collection-section__item" role="listitem">
              {% render 'grid-item', product: product, sizes: image_sizes %}
            </div>
          {% endfor %}
        {% else %}
          {% for i in (1..products_to_show) %}
            {% liquid
              assign placeholder_index = i | modulo: 6

              if placeholder_index == 0
                assign placeholder_index = 6
              endif
            %}
            <div class="featured-collection-section__item" role="listitem">
              {% render 'grid-item', placeholder_index: placeholder_index, sizes: image_sizes %}
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>

    {% if show_view_all and featured_collection != blank and view_all_position == 'below' %}
      <div class="featured-collection-section__footer">
        <a
          class="featured-collection-section__view-all-link{% if view_all_style == 'primary' %} button button--primary{% elsif view_all_style == 'secondary' %} button button--secondary{% endif %}"
          href="{{ featured_collection.url }}"
        >
          {{ 'View all' }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .featured-collection-section {
    width: 100%;
    padding: 56px 0;
  }

  .featured-collection-section--divider {
    border-top: 1px solid rgba(16, 24, 32, 0.12);
  }

  .featured-collection-section__inner {
    width: min(var(--page-width), calc(100% - var(--page-margin) * 2));
    margin: 0 auto;
  }

  .featured-collection-section__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
  }

  .featured-collection-section__heading {
    margin: 0;
  }

  .featured-collection-section__view-all-link {
    color: inherit;
    text-underline-offset: 0.18em;
  }

  .featured-collection-section__view-all-link.button {
    text-decoration: none;
  }

  .featured-collection-section__grid {
    display: grid;
    grid-template-columns: repeat(var(--featured-collection-columns), minmax(0, 1fr));
    gap: 24px;
  }

  .featured-collection-section__item {
    min-width: 0;
  }

  .featured-collection-card {
    height: 100%;
  }

  .featured-collection-card__link {
    display: block;
    height: 100%;
    color: inherit;
    text-decoration: none;
  }

  .featured-collection-card__media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background: #f3f4f6;
    border-radius: var(--style-border-radius-product-tile);
  }

  .featured-collection-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .featured-collection-card__image--placeholder {
    background: linear-gradient(135deg, #e7ebf0, #d8e0ea);
    fill: rgba(16, 24, 32, 0.2);
  }

  .featured-collection-card__link:hover .featured-collection-card__image,
  .featured-collection-card__link:focus-visible .featured-collection-card__image {
    transform: scale(1.03);
  }

  .featured-collection-card__content {
    padding-top: 14px;
  }

  .featured-collection-card__title {
    margin: 0;
    font-size: 1rem;
    line-height: 1.35;
  }

  .featured-collection-card__price {
    margin-top: 6px;
    color: rgba(16, 24, 32, 0.72);
  }

  .featured-collection-section__footer {
    margin-top: 24px;
  }

  @media (max-width: 989px) {
    .featured-collection-section__grid {
      grid-template-columns: repeat(min(var(--featured-collection-columns), 2), minmax(0, 1fr));
    }
  }

  @media (max-width: 749px) {
    .featured-collection-section {
      padding: 40px 0;
    }

    .featured-collection-section__header {
      align-items: flex-start;
      margin-bottom: 20px;
    }

    .featured-collection-section__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
    }

    .featured-collection-section__grid-wrapper--mobile-swipe {
      overflow-x: auto;
      scroll-snap-type: x proximity;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .featured-collection-section__grid-wrapper--mobile-swipe::-webkit-scrollbar {
      display: none;
    }

    .featured-collection-section__grid-wrapper--mobile-swipe .featured-collection-section__grid {
      display: flex;
      gap: 16px;
    }

    .featured-collection-section__grid-wrapper--mobile-swipe .featured-collection-section__item {
      width: min(78vw, 320px);
      flex: 0 0 min(78vw, 320px);
      scroll-snap-align: start;
    }

    .featured-collection-section__footer {
      margin-top: 20px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured collection",
  "tag": "section",
  "class": "section-featured-collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_per_row",
      "label": "Products per row",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "rows",
      "label": "Rows of products",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 1
    },
    {
      "type": "checkbox",
      "id": "enable_swipe_on_mobile",
      "label": "Enable swipe on mobile",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' link",
      "default": true
    },
    {
      "type": "select",
      "id": "view_all_position",
      "label": "View all link next to heading or under collection",
      "options": [
        {
          "value": "header",
          "label": "Next to heading"
        },
        {
          "value": "below",
          "label": "Under collection"
        }
      ],
      "default": "header"
    },
    {
      "type": "select",
      "id": "view_all_style",
      "label": "View all style",
      "options": [
        {
          "value": "link",
          "label": "Inline link"
        },
        {
          "value": "primary",
          "label": "Primary button"
        },
        {
          "value": "secondary",
          "label": "Secondary button"
        }
      ],
      "default": "link"
    },
    {
      "type": "checkbox",
      "id": "show_section_divider",
      "label": "Show section divider",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}
